# Solar Permit Validator Configuration
# Copy to .env and fill in your values

# LLM Provider: mock | gemini | openai
LLM_PROVIDER=mock

# Gemini API Key (for production extraction)
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI API Key (alternative)
# OPENAI_API_KEY=sk-...

# Server settings
HOST=0.0.0.0
PORT=8000
